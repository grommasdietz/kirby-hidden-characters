# Keep the repository useful for development while GitHub tag archives and Composer exports contain only runtime files.

# Git / GitHub
.DS_Store export-ignore
.gitattributes export-ignore
.github/ export-ignore
.gitignore export-ignore
__MACOSX/ export-ignore

# Playground (development-only)
playground/ export-ignore

# Dev tooling
.editorconfig export-ignore
.husky/ export-ignore
.markdownlint.json export-ignore
.node-version export-ignore
.php-cs-fixer.cache export-ignore
.php-cs-fixer.dist.php export-ignore
.phpunit.cache/ export-ignore
.prettierignore export-ignore
.releaserc export-ignore
.vscode/ export-ignore
commitlint.config.cjs export-ignore
eslint.config.cjs export-ignore
phpunit.xml.dist export-ignore
playwright.config.ts export-ignore
postcss.config.cjs export-ignore
psalm.xml.dist export-ignore

# Dependency manager metadata (not needed at runtime)
composer.lock export-ignore
node_modules/ export-ignore
package.json export-ignore
pnpm-lock.yaml export-ignore
pnpm-workspace.yaml export-ignore
test-results/ export-ignore
tsconfig.json export-ignore
vendor/ export-ignore
kirby/ export-ignore

# Markdown (development only)
AGENTS.md export-ignore
CONTRIBUTING.md export-ignore
SECURITY.md export-ignore
STYLE_GUIDE.md export-ignore

# Source + tests (runtime artifacts are index.php, compiled index.{js,css}, and assets/fonts/)
dist/ export-ignore
docs/ export-ignore
licenses/ export-ignore
src/ export-ignore
tests/ export-ignore
tools/ export-ignore
